# Common runtime
APP_ENV=development
LOG_LEVEL=INFO
TRACE_HEADER=X-Trace-Id
SESSION_EXPORT_DIR=data/exports
MEDIA_STORAGE_ROOT=data/derived/live_media

# Web
# These values are the canonical browser config inputs, but the static `apps/web`
# shell does not read `.env` directly. Inject them into `window.__APP_CONFIG__`
# or template them into the served HTML during deployment.
WEB_PUBLIC_API_BASE_URL=http://localhost:8000
WEB_PUBLIC_WS_URL=ws://localhost:8000/ws
WEB_PUBLIC_TTS_BASE_URL=http://localhost:8040
WEB_PUBLIC_AFFECT_BASE_URL=http://localhost:8060
WEB_DEFAULT_AVATAR_ID=companion_female_01
WEB_AUTOPLAY_ASSISTANT_AUDIO=true

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_PUBLIC_BASE_URL=http://localhost:8000
GATEWAY_WS_PATH=/ws
GATEWAY_CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:3000,http://localhost:3000

# Orchestrator
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8010
ORCHESTRATOR_BASE_URL=http://127.0.0.1:8010
ORCHESTRATOR_REQUEST_TIMEOUT_SECONDS=60

# Dialogue Service
DIALOGUE_SERVICE_HOST=0.0.0.0
DIALOGUE_SERVICE_PORT=8030
DIALOGUE_SERVICE_BASE_URL=http://127.0.0.1:8030

# Affect Service
AFFECT_SERVICE_HOST=0.0.0.0
AFFECT_SERVICE_PORT=8060
AFFECT_SERVICE_BASE_URL=http://127.0.0.1:8060
AFFECT_CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:3000,http://localhost:3000

# RAG Service
RAG_SERVICE_HOST=0.0.0.0
RAG_SERVICE_PORT=8070
RAG_SERVICE_BASE_URL=http://127.0.0.1:8070
RAG_CARDS_PATH=data/kb/knowledge_cards.jsonl
RAG_DEFAULT_TOP_K=3
RAG_MAX_TOP_K=5

# PostgreSQL
DATABASE_URL=postgresql://app:change_me@localhost:5432/virtual_human
POSTGRES_URL=postgresql://app:change_me@localhost:5432/virtual_human
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=virtual_human
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_RAW=vdh-raw
MINIO_BUCKET_DERIVED=vdh-derived
MINIO_BUCKET_LOGS=vdh-logs

# LLM
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.2
LLM_TIMEOUT_SECONDS=60
LLM_CONTEXT_WINDOW=8192
DIALOGUE_FORCE_FAILURE_MODE=

# ASR
ASR_SERVICE_HOST=0.0.0.0
ASR_SERVICE_PORT=8020
ASR_SERVICE_BASE_URL=http://127.0.0.1:8020
ASR_CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:3000,http://localhost:3000
ASR_PROVIDER=dashscope
ASR_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
ASR_API_KEY=
ASR_MODEL=qwen3-asr-flash
ASR_LANGUAGE_HINT=auto
ASR_TIMEOUT_SECONDS=60
ASR_MODEL_PATH=
ASR_POSTPROCESS_ENABLED=true
ASR_SILENCE_WINDOW_MS=200
ASR_SILENCE_MIN_DURATION_MS=350
ASR_SILENCE_THRESHOLD_RATIO=0.015
ASR_HOTWORD_MAP_PATH=services/asr-service/hotwords.json

# TTS
TTS_SERVICE_HOST=0.0.0.0
TTS_SERVICE_PORT=8040
TTS_SERVICE_BASE_URL=http://127.0.0.1:8040
TTS_CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:3000,http://localhost:3000
TTS_PROVIDER=edge_tts
TTS_BASE_URL=
TTS_API_KEY=
TTS_MODEL=
TTS_VOICE_A=companion_female_01
TTS_VOICE_B=coach_male_01
TTS_AUDIO_FORMAT=mp3
TTS_EDGE_TIMEOUT_SECONDS=18
TTS_ENABLE_WAVE_FALLBACK=true
TTS_MODEL_PATH=
TTS_STORAGE_ROOT=data/derived/tts_audio

# Avatar driver
AVATAR_DRIVER_HOST=127.0.0.1
AVATAR_DRIVER_PORT=8050
AVATAR_PROTOCOL_VERSION=v1
AVATAR_DEFAULT_ID_A=companion_female_01
AVATAR_DEFAULT_ID_B=coach_male_01
AVATAR_MODEL_PATH=
